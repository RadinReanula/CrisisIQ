# Supabase (frontend — safe to expose)
VITE_SUPABASE_URL=https://[your-project].supabase.co
VITE_SUPABASE_ANON_KEY=[your-anon-key]

# Netlify Functions (server-side only — set in Netlify dashboard for prod)
OPENAI_API_KEY=[your-openai-key]
# Optional model overrides. Defaults are conservative and cost-efficient.
# Triage + sitrep use Chat Completions JSON mode.
OPENAI_MODEL=gpt-4o-mini
# AI news uses the Responses API with the web_search tool, so the model
# must support tools / web_search (e.g. gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini).
OPENAI_NEWS_MODEL=gpt-4o-mini

# Server-side Supabase access used by Netlify Functions (no VITE_ prefix).
SUPABASE_URL=https://[your-project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]
